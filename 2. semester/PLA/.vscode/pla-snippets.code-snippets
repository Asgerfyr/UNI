  "Matrix Rank": {
    "prefix": ["rank", "rang", "matrix-rank"],
    "body": [
      "# Calculate the rank of a matrix",
      "# Formula: $\\text{rank}(\\mathbf{A})$ = number of linearly independent rows/columns",
      "#",
      "# PROVIDE:",
      "#   ${1:A} = matrix to analyze",
      "#   ${2:rank} = result variable (integer)",
      "#",
      "# MEANING:",
      "# - Rank = dimension of column space (and row space)",
      "# - Full rank: rank = min(rows, cols)",
      "# - Rank-deficient: rank < min(rows, cols)",
      "#",
      "# USAGE: Check invertibility, count independent equations,",
      "#        determine nullspace dimension",
      "",
      "${2:rank} = np.linalg.matrix_rank(${1:A})"
    ],
    "description": "Calculate matrix rank"
  },

  "Matrix Determinant": {
    "prefix": ["det", "determinant", "determinant"],
    "body": [
      "# Calculate determinant of a square matrix",
      "# Formula: $\\det(\\mathbf{A})$ (scalar value)",
      "#",
      "# PROVIDE:",
      "#   ${1:A} = square matrix (n×n)",
      "#   ${2:det} = result variable (scalar)",
      "#",
      "# MEANING:",
      "# - det(A) = 0 → matrix is singular (not invertible)",
      "# - det(A) ≠ 0 → matrix is invertible",
      "# - |det(A)| = volume scaling factor of transformation",
      "#",
      "# PROPERTIES:",
      "# - det(AB) = det(A)×det(B)",
      "# - det(A^T) = det(A)",
      "# - det(A^-1) = 1/det(A)",
      "",
      "${2:det} = np.linalg.det(${1:A})"
    ],
    "description": "Calculate matrix determinant"
  },

  "Matrix Trace": {
    "prefix": ["trace", "spor", "tr"],
    "body": [
      "# Calculate trace: sum of diagonal elements",
      "# Formula: $\\text{tr}(\\mathbf{A}) = \\sum_{i=1}^{n} a_{ii} = a_{11} + a_{22} + ... + a_{nn}$",
      "#",
      "# PROVIDE:",
      "#   ${1:A} = square matrix (n×n)",
      "#   ${2:trace} = result variable (scalar)",
      "#",
      "# PROPERTIES:",
      "# - tr(A + B) = tr(A) + tr(B)",
      "# - tr(cA) = c×tr(A)",
      "# - tr(AB) = tr(BA) (cyclic property)",
      "# - tr(A) = sum of eigenvalues",
      "#",
      "# USAGE: Matrix analysis, eigenvalue sums",
      "",
      "${2:trace} = np.trace(${1:A})"
    ],
    "description": "Calculate matrix trace"
  },

