    ],
    "description": "Calculate matrix inverse and verify"
  },

  "Inverse Properties": {
    "prefix": ["inverse-props", "invers-egenskaber"],
    "body": [
      "# Verify matrix inverse properties",
      "#",
      "# PROVIDE:",
      "#   ${2:A}, ${4:B} = invertible matrices",
      "#",
      "# PROPERTIES TO VERIFY:",
      "# 1. $(\\mathbf{A}^{-1})^{-1} = \\mathbf{A}$ (inverse of inverse)",
      "# 2. $(\\mathbf{AB})^{-1} = \\mathbf{B}^{-1}\\mathbf{A}^{-1}$ (reverse order!)",
      "# 3. $(\\mathbf{A}^T)^{-1} = (\\mathbf{A}^{-1})^T$ (commutes with transpose)",
      "#",
      "# USAGE: Understanding inverse algebra, checking calculations",
      "",
      "# 1. $(\\mathbf{A}^{-1})^{-1} = \\mathbf{A}$",
      "${1:A_inv_inv} = np.linalg.inv(np.linalg.inv(${2:A}))",
      "print(f\"Property 1: {np.allclose(${1:A_inv_inv}, ${2:A})}\")",
      "",
      "# 2. $(\\mathbf{AB})^{-1} = \\mathbf{B}^{-1}\\mathbf{A}^{-1}$",
      "${3:AB_inv} = np.linalg.inv(${2:A} @ ${4:B})",
      "${5:B_inv_A_inv} = np.linalg.inv(${4:B}) @ np.linalg.inv(${2:A})",
      "print(f\"Property 2: {np.allclose(${3:AB_inv}, ${5:B_inv_A_inv})}\")",
