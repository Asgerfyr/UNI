  "Linear Regression": {
    "prefix": ["regression", "linear-model", "beta"],
    "body": [
      "# Linear Regression: Fit a linear model to data",
      "# Formula: $\\mathbf{y} = \\mathbf{D} \\boldsymbol{\\beta} + \\boldsymbol{\\epsilon}$",
      "# Solution: $\\hat{\\boldsymbol{\\beta}} = (\\mathbf{D}^T \\mathbf{D})^{-1} \\mathbf{D}^T \\mathbf{y}$",
      "#",
      "# PROVIDE:",
      "#   ${2:data} = pandas DataFrame with your data",
      "#   ${3:x} = name of predictor column (e.g., 'Weight')",
      "#   ${5:y} = name of response column (e.g., 'Density')",
      "#   ${1:D} = design matrix (includes intercept column)",
      "#   ${6:Beta_hat} = estimated coefficients [β₀, β₁, ...]",
      "#",
      "# WHAT YOU GET:",
      "# Beta_hat[0] = intercept (β₀)",
      "# Beta_hat[1] = slope for x (β₁)",
      "# Model: y = β₀ + β₁*x",
      "#",
      "# EXAMPLE: Predict density from weight",
      "#   D = [[1, w₁], [1, w₂], ...] (1's for intercept)",
      "#   y = [d₁, d₂, ...]",
      "#   Beta_hat = [intercept, weight_coefficient]",
      "",
      "# Design matrix: add column of 1's for intercept",
      "${1:D} = np.column_stack((np.ones(len(${2:data})), ${2:data}['${3:x}']))",
      "",
      "# Response vector",
      "${4:y} = ${2:data}['${5:y}'].to_numpy()",
      "",
      "# Estimate coefficients using normal equations",
      "${6:Beta_hat} = np.linalg.inv(${1:D}.T @ ${1:D}) @ ${1:D}.T @ ${4:y}",
      "",
      "print(f\"Beta coefficients:\\n{${6:Beta_hat}}\")",
      "print(f\"Model: y = {${6:Beta_hat}[0]:.4f} + {${6:Beta_hat}[1]:.4f}*x\")"
    ],
    "description": "Perform linear regression"
  },

  "F-Test": {
    "prefix": ["ftest", "f-test", "nested-models"],
    "body": [
      "# F-test for nested linear regression models",
      "#",
      "# PROVIDE:",
      "#   ${2:design_matrix_full} = full model design matrix (more predictors)",
      "#   ${5:design_matrix_restricted} = restricted model design matrix (fewer predictors)",
      "#   ${8:y} = response vector",
      "#   ${14:alpha} = significance level (0.05)",
      "#",
      "# PURPOSE: Test if extra predictors significantly improve fit",
      "#",
      "# FORMULA: $T = \\frac{(SSE_R - SSE_F)/(p_F - p_R)}{SSE_F / (n - p_F)}$",
      "#",
      "# INTERPRETATION:",
      "# - T ≥ F_crit \u2192 reject null, full model is significantly better",
      "# - T < F_crit \u2192 fail to reject, restricted model is sufficient",
      "#",
      "# USAGE: Model comparison, variable selection in regression",
      "",
      "from scipy.stats import f",
      "",
      "# Full model: D_F",
      "${1:D_F} = ${2:design_matrix_full}",
      "${3:p_F} = ${1:D_F}.shape[1]",
      "",
      "# Restricted model: D_R",
      "${4:D_R} = ${5:design_matrix_restricted}",
      "${6:p_R} = ${4:D_R}.shape[1]",
      "",
      "${7:n} = len(${8:y})",
      "",
      "# Estimate beta for both models",
      "${9:Beta_hat_F} = np.linalg.inv(${1:D_F}.T @ ${1:D_F}) @ ${1:D_F}.T @ ${8:y}",
      "${10:Beta_hat_R} = np.linalg.inv(${4:D_R}.T @ ${4:D_R}) @ ${4:D_R}.T @ ${8:y}",
      "",
      "# Sum of squared errors",
      "${11:SSE_F} = np.linalg.norm(${8:y} - ${1:D_F} @ ${9:Beta_hat_F})**2",
      "${12:SSE_R} = np.linalg.norm(${8:y} - ${4:D_R} @ ${10:Beta_hat_R})**2",
      "",
      "# F-statistic: $T = \\frac{(SSE_R - SSE_F)/(p_F - p_R)}{SSE_F / (n - p_F)}$",
      "${13:T} = ((${12:SSE_R} - ${11:SSE_F}) / (${3:p_F} - ${6:p_R})) / (${11:SSE_F} / (${7:n} - ${3:p_F}))",
      "",
      "${14:alpha} = 0.05",
      "${15:F_crit} = f.ppf(1 - ${14:alpha}, ${3:p_F} - ${6:p_R}, ${7:n} - ${3:p_F})",
      "",
      "print(f\"F-statistic: {${13:T}}\")",
      "print(f\"Critical value: {${15:F_crit}}\")",
      "",
      "if ${13:T} >= ${15:F_crit}:",
      "    print(\"Reject null hypothesis: Full model is better\")",
      "else:",
      "    print(\"Fail to reject null hypothesis\")"
    ],
    "description": "Perform F-test for nested models"
  },

