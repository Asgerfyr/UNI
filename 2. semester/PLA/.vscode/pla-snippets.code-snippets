      "print(f\"D =\\n{np.round(${5:D}, 2)}\")",
      "print(f\"V^-1 =\\n{np.round(${6:V_inv}, 2)}\")",
      "",
      "# Verify: V @ D @ V^-1 should equal A",
      "${7:A_reconstructed} = ${4:V} @ ${5:D} @ ${6:V_inv}",
