  "Vector Norms": {
    "prefix": ["norm", "normer", "vector-norm", "længde"],
    "body": [
      "# Calculate different vector norms (lengths)",
      "# ",
      "# PROVIDE:",
      "#   ${1:v} = your vector variable",
      "#",
      "# FORMULAS:",
      "# L∞ norm (max norm): $\\\\lVert \\mathbf{v} \\\\rVert_\\infty = \\max|v_i|$ (largest absolute value)",
      "# L1 norm (Manhattan): $\\\\lVert \\mathbf{v} \\\\rVert_1 = \\sum|v_i|$ (sum of absolute values)",
      "# L2 norm (Euclidean): $\\\\lVert \\mathbf{v} \\\\rVert_2 = \\sqrt{\\sum v_i^2}$ (standard distance)",
      "",
      "${1:v}_norm_inf = np.linalg.norm(${1:v}, ord=np.inf)  # L∞: Maximum absolute value",
      "${1:v}_norm_1 = np.linalg.norm(${1:v}, ord=1)          # L1: Sum of absolutes",
      "${1:v}_norm_2 = np.linalg.norm(${1:v}, ord=2)          # L2: Euclidean distance",
      "",
      "# Manual L2 norm calculation (for understanding):",
      "${1:v}_norm_2_manual = np.sqrt(np.sum(${1:v}**2))"
    ],
    "description": "Calculate vector norms (L∞, L1, L2)"
  },

  "Dot Product": {
    "prefix": ["dot", "inner", "prikprodukt", "indre-produkt"],
    "body": [
      "# Dot product (inner product, scalar product)",
      "# Formula: $\\mathbf{u} \\cdot \\mathbf{v} = \\sum_{i=1}^{n} u_i v_i = u_1v_1 + u_2v_2 + ... + u_nv_n$",
      "#",
      "# PROVIDE:",
      "#   ${1:u} = first vector",
      "#   ${2:v} = second vector (must have same length as u)",
      "#   ${3:dot_product} = variable name for result (will be a scalar/number)",
      "#",
      "# USAGE: Measures how aligned two vectors are. Result = 0 if perpendicular.",
      "",
      "${3:dot_product} = np.dot(${1:u}, ${2:v})"
    ],
    "description": "Calculate dot product (inner product)"
  },

  "Vector Distance": {
    "prefix": ["distance", "afstand", "vector-distance"],
    "body": [
      "# Calculate distance between two vectors",
      "# Formula: $d(\\mathbf{u}, \\mathbf{v}) = \\\\lVert \\mathbf{u} - \\mathbf{v} \\\\rVert_p$",
      "#",
      "# PROVIDE:",
      "#   ${1:u} = first vector",
      "#   ${2:v} = second vector",
      "#   ${3:diff} = variable for difference vector",
      "#   ${4:distance} = variable for result",
      "#   ${5:2} = norm type (1 for Manhattan, 2 for Euclidean, np.inf for max)",
