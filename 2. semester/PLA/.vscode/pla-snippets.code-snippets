  "Matrix Inverse": {
    "prefix": ["inverse", "invers", "inv"],
    "body": [
      "# Calculate the inverse of a matrix",
      "# Formula: $\\mathbf{A}^{-1}$ such that $\\mathbf{A}\\mathbf{A}^{-1} = \\mathbf{A}^{-1}\\mathbf{A} = \\mathbf{I}$",
      "#",
      "# PROVIDE:",
      "#   ${1:A} = square invertible matrix (det(A) ≠ 0)",
      "#   ${2:A_inv} = result variable for inverse",
      "#",
      "# REQUIREMENTS:",
      "#   - A must be square (n×n)",
      "#   - A must be invertible (det(A) ≠ 0, full rank)",
      "#",
      "# USAGE: Solving Ax = b as x = A⁻¹b, finding transformations",
      "",
      "${2:A_inv} = np.linalg.inv(${1:A})",
      "",
      "# Verify: should be identity matrix",
