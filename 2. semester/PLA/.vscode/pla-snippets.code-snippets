      "#   ${1:A} = matrix to analyze",
      "#   ${5:x} = vector to test if in nullspace",
      "#   ${6:values} = components of test vector",
      "#",
      "# WHAT IS NULLSPACE:",
      "# - All vectors that A maps to zero",
      "# - Solutions to homogeneous system Ax = 0",
      "# - Dimension = n - rank(A) where n = number of columns",
      "#",
      "# EXAMPLES:",
      "# - If A is 3×3 with rank 2, nullspace is 1D (a line)",
      "# - If A is 4×5 with rank 3, nullspace is 2D (a plane)",
      "# - If A has full column rank, nullspace = {0} (only zero vector)",
      "",
      "${2:n} = ${1:A}.shape[1]",
      "${3:rank} = np.linalg.matrix_rank(${1:A})",
      "${4:nullspace_dim} = ${2:n} - ${3:rank}",
      "",
      "print(f\"Dimension of nullspace: {${4:nullspace_dim}}\")",
      "",
      "# Check if a specific vector belongs to nullspace",
      "${5:x} = np.array([${6:values}])",
      "${7:result} = ${1:A} @ ${5:x}",
