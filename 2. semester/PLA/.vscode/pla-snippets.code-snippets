  "PCA Analysis": {
    "prefix": ["pca", "principal-component"],
    "body": [
      "# Principal Component Analysis (PCA): Find main directions of variance",
      "#",
      "# PROVIDE:",
      "#   ${2:data} = pandas DataFrame or numpy array with observations×features",
      "#   ${7:k} = number of principal components to keep (${8:2})",
      "#   ${9:components} = transformed data in new coordinate system",
      "#",
      "# 5 STEPS OF PCA:",
      "# 1. Mean-center: subtract mean from each feature",
      "# 2. Covariance matrix: shows how features vary together",
      "# 3. Eigendecomposition: find principal directions",
      "# 4. Sort: order by importance (largest eigenvalue first)",
      "# 5. Project: transform data to new coordinates",
      "#",
      "# WHAT YOU GET:",
      "# - evals: Variance captured by each component",
      "# - evecs: Principal directions (new axes)",
      "# - components: Data in new coordinate system",
      "#",
      "# USAGE: Dimensionality reduction, visualization, feature extraction",
      "",
      "# Step 1: Mean-center the data",
      "${1:X} = ${2:data}.values",
      "${1:X} = ${1:X} - np.mean(${1:X}, axis=0, keepdims=True)",
      "",
      "# Step 2: Covariance matrix",
      "${3:covmat} = ${1:X}.T @ ${1:X} / (${1:X}.shape[0] - 1)",
      "",
      "# Step 3: Eigendecomposition",
      "${4:evals}, ${5:evecs} = np.linalg.eig(${3:covmat})",
      "",
      "# Step 4: Sort by eigenvalues (descending)",
      "${6:sidx} = np.argsort(${4:evals})[::-1]",
      "${4:evals} = ${4:evals}[${6:sidx}]",
      "${5:evecs} = ${5:evecs}[:, ${6:sidx}]",
      "",
      "# Step 5: Project data onto first k components",
      "${7:k} = ${8:2}  # Adjust based on scree plot",
      "${9:components} = ${1:X} @ ${5:evecs}[:, :${7:k}]",
      "",
      "print(f\"Component scores shape: {${9:components}.shape}\")"
    ],
    "description": "Perform PCA analysis"
  },

