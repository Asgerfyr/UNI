      "# USAGE: Measures how far apart two vectors are in space",
      "",
      "${3:diff} = ${1:u} - ${2:v}",
      "${4:distance} = np.linalg.norm(${3:diff}, ord=${5:2})"
    ],
    "description": "Calculate distance between vectors"
  },

  "Linear Independence Check": {
    "prefix": ["lindep", "linear-independence", "lineær-uafhængighed"],
    "body": [
      "# Check if vectors are linearly independent",
      "# ",
      "# CONCEPT: Vectors are independent if none can be written as a linear",
      "#          combination of the others. Uses rank to check.",
      "# ",
      "# PROVIDE:",
      "#   ${1:is_independent} = variable for result (True/False)",
      "#   ${2:v1}, ${3:v2} = your vectors to check",
      "#",
      "# HOW IT WORKS:",
      "# - Stacks vectors as columns of a matrix",
      "# - If rank(matrix) == number of vectors → independent",
      "# - If rank(matrix) < number of vectors → dependent",
      "",
      "def lindcheck(vectors):",
      "    \"\"\"Check if vectors are linearly independent\"\"\"",
      "    matrix = np.column_stack(vectors)",
      "    rank = np.linalg.matrix_rank(matrix)",
      "    return rank == len(vectors)",
      "",
      "${1:is_independent} = lindcheck([${2:v1}, ${3:v2}])"
    ],
    "description": "Check if vectors are linearly independent"
  },

  "Vector Projection": {
    "prefix": ["projection", "projektion", "proj"],
    "body": [
      "# Project vector u onto vector v (decompose u into parallel and perpendicular parts)",
      "#",
      "# FORMULAS:",
      "# Parallel component: $\\mathbf{u}_{\\parallel} = \\frac{\\mathbf{u} \\cdot \\mathbf{v}}{\\mathbf{v} \\cdot \\mathbf{v}} \\mathbf{v}$",
      "# Perpendicular component: $\\mathbf{u}_{\\perp} = \\mathbf{u} - \\mathbf{u}_{\\parallel}$",
      "#",
      "# PROVIDE:",
      "#   ${1:u} = vector to project",
      "#   ${2:v} = vector to project onto",
      "#   ${3:u_parallel} = parallel component (shadow of u on v)",
      "#   ${4:u_perp} = perpendicular component (what's left)",
      "#",
      "# USAGE: Decomposes u into a part along v and a part perpendicular to v",
      "",
      "${3:u_parallel} = (np.dot(${1:u}, ${2:v}) / np.dot(${2:v}, ${2:v})) * ${2:v}",
      "",
      "${4:u_perp} = ${1:u} - ${3:u_parallel}",
      "",
      "# Verify orthogonality: $\\mathbf{${3:u_parallel}} \\cdot \\mathbf{${4:u_perp}} = 0$",
      "print(f\"Orthogonal: {np.abs(np.dot(${3:u_parallel}, ${4:u_perp})) < 1e-10}\")"
    ],
    "description": "Project vector u onto v and find orthogonal component"
  },

  "Orthogonal Basis Check": {
    "prefix": ["orthogonal", "ortogonal", "orthonormal"],
    "body": [
      "# Check if vectors form an orthogonal or orthonormal basis",
      "#",
      "# PROVIDE:",
      "#   ${1:is_ortho} = result variable (True/False)",
      "#   ${2:v1}, ${3:v2}, ${4:v3} = vectors to check",
      "#",
      "# DEFINITIONS:",
      "# - Orthogonal: dot product between any two different vectors = 0",
      "# - Orthonormal: orthogonal AND each vector has length = 1",
      "#",
      "# USAGE: Verify basis vectors for QR decomposition, PCA, etc.",
      "",
      "def is_orthogonal(vectors):",
      "    \"\"\"Check if vectors form an orthogonal basis\"\"\"",
      "    for i in range(len(vectors)):",
      "        for j in range(i+1, len(vectors)):",
      "            if np.abs(np.dot(vectors[i], vectors[j])) > 1e-10:",
      "                return False",
      "    return True",
      "",
      "def is_orthonormal(vectors):",
      "    \"\"\"Check if vectors form an orthonormal basis\"\"\"",
      "    if not is_orthogonal(vectors):",
      "        return False",
      "    for vec in vectors:",
      "        if np.abs(np.linalg.norm(vec) - 1) > 1e-10:",
      "            return False",
      "    return True",
      "",
      "${1:is_ortho} = is_orthogonal([${2:v1}, ${3:v2}, ${4:v3}])"
    ],
    "description": "Check if vectors are orthogonal or orthonormal"
  },

  "Normalize Vector": {
    "prefix": ["normalize", "normaliser", "unit-vector"],
    "body": [
      "# Normalize a vector to unit length (length = 1)",
      "# Formula: $\\hat{\\mathbf{v}} = \\frac{\\mathbf{v}}{\\\\lVert \\mathbf{v} \\\\rVert}$",
      "#",
      "# PROVIDE:",
      "#   ${1:v} = vector to normalize",
      "#   ${2:v_normalized} = result variable (unit vector in same direction)",
      "#",
      "# USAGE: Creates a vector pointing in same direction but with length 1",
      "#        Used for orthonormal bases",
      "",
      "${2:v_normalized} = ${1:v} / np.linalg.norm(${1:v})"
    ],
    "description": "Normalize a vector to unit length"
  },
  "Triangle Inequality": {
    "prefix": ["triangle", "triangel-ulighed", "triangle-inequality"],
    "body": [
      "# Verify triangle inequality",
      "# Formula: $\\\\lVert \\mathbf{u} + \\mathbf{v} \\\\rVert \\leq \\\\lVert \\mathbf{u} \\\\rVert + \\\\lVert \\mathbf{v} \\\\rVert$",
      "#",
      "# PROVIDE:",
      "#   ${1:u}, ${2:v} = two vectors",
      "#   ${5:2} = norm type (1, 2, or np.inf)",
      "#",
      "# MEANING:",
      "# The length of the sum is at most the sum of the lengths.",
      "# Think of a triangle: one side ≤ sum of other two sides.",
      "#",
      "# SHOULD ALWAYS BE TRUE for any valid norm!",
      "",
      "${3:sum_vec} = ${1:u} + ${2:v}",
      "${4:lhs} = np.linalg.norm(${3:sum_vec}, ord=${5:2})",
      "${6:rhs} = np.linalg.norm(${1:u}, ord=${5:2}) + np.linalg.norm(${2:v}, ord=${5:2})",
      "print(f\"Triangle inequality holds: {${4:lhs} <= ${6:rhs}}\")"
    ],
    "description": "Verify triangle inequality"
  },

  "Cauchy-Schwarz": {
    "prefix": ["cauchy", "cauchy-schwarz", "cs-inequality"],
    "body": [
      "# Verify Cauchy-Schwarz inequality",
      "# Formula: $|\\mathbf{u} \\cdot \\mathbf{v}| \\leq \\\\lVert \\mathbf{u} \\\\rVert \\\\lVert \\mathbf{v} \\\\rVert$",
      "#",
      "# PROVIDE:",
      "#   ${1:u}, ${2:v} = two vectors",
      "#",
      "# MEANING:",
      "# The absolute dot product is at most the product of the lengths.",
      "# Equality when vectors are parallel.",
      "# Zero when vectors are perpendicular.",
      "#",
      "# FUNDAMENTAL INEQUALITY - always true!",
      "# Used to prove triangle inequality.",
      "",
      "${3:lhs} = np.abs(np.dot(${1:u}, ${2:v}))",
      "${4:rhs} = np.linalg.norm(${1:u}) * np.linalg.norm(${2:v})",
      "print(f\"Cauchy-Schwarz holds: {${3:lhs} <= ${4:rhs}}\")"
    ],
    "description": "Verify Cauchy-Schwarz inequality"
  },

