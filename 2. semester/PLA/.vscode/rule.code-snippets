    "prefix": "rule-cayley-hamilton",
    "body": [
      "# Cayley-Hamilton Theorem:",
      "# Every square matrix satisfies its characteristic equation",
      "# If p(λ) = det(λI - A) = λⁿ + c_(n-1)λ^(n-1) + ... + c_0",
      "# Then p(A) = 0 (using A instead of λ)",
      "# Useful for: computing A^n without explicit power, finding A^(-1)",
