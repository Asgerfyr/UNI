  "rule-frobenius-norm": {
    "prefix": "rule-frobenius-norm",
    "body": [
      "# Frobenius Norm: ||A||_F = √(Σ a_ij²)",
      "# Alternatively: ||A||_F = √(trace(A^T A))",
      "# Or: ||A||_F = √(Σ σ_i²) where σ_i are singular values",
      "A_frob_norm = np.linalg.norm(A, 'fro')",
      "# Verification via trace",
      "A_frob_trace = np.sqrt(np.trace(A.T @ A))",
      "# Verification via singular values",
      "_, s, _ = np.linalg.svd(A)",
      "A_frob_svd = np.sqrt(np.sum(s**2))",
