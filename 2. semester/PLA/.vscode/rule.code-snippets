    "description": "Spectral Norm (2-norm) properties"
  },
  "rule-condition-number": {
    "prefix": "rule-condition-number",
    "body": [
      "# Condition Number: κ(A) = ||A|| * ||A^(-1)||",
      "# Or with spectral norm: κ(A) = σ_max / σ_min",
      "# Interpretation: measure of numerical stability",
      "# Large κ means ill-conditioned (sensitive to perturbations)",
      "cond_number = np.linalg.cond(A)",
      "# Verification via singular values",
      "_, s, _ = np.linalg.svd(A)",
      "cond_from_svd = s[0] / s[-1]",
      "assert np.isclose(cond_number, cond_from_svd)"
