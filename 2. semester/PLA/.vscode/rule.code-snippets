      "# Column space: span of columns of A (subspace of R^m)",
      "# Null space: solutions to Ax = 0 (subspace of R^n)",
      "# Left null space: solutions to A^T y = 0 (subspace of R^m)",
      "# Row space dimension = Column space dimension = rank(A)",
