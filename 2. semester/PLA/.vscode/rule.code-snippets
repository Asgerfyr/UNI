    "description": "Cayley-Hamilton Theorem"
  },
  "rule-matrix-power": {
    "prefix": "rule-matrix-power",
    "body": [
      "# Computing A^n efficiently:",
      "# If A = PDP^(-1) (diagonalizable):",
      "# A^n = PD^nP^(-1)",
      "# For orthogonal A = QΛQ^T:",
      "# A^n = QΛ^nQ^T",
      "eigenvalues, eigenvectors = np.linalg.eig(A)",
      "P = eigenvectors",
      "D_n = np.diag(eigenvalues ** n)",
      "P_inv = np.linalg.inv(P)",
      "A_n = P @ D_n @ P_inv",
      "# Verify",
