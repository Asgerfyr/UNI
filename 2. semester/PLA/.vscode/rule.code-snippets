  "rule-diagonalization": {
    "prefix": "rule-diagonalization",
    "body": [
      "# Diagonalization: A = PDP^(-1)",
      "# Where D is diagonal (eigenvalues on diagonal)",
      "# And P has eigenvectors as columns",
