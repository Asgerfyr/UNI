    "description": "Orthonormal vectors properties"
  },
  "rule-norm-preservation": {
    "prefix": "rule-norm-preserve",
    "body": [
      "# Orthogonal matrix preserves norms:",
      "# ||Qx|| = ||x||",
      "# Proof: ||Qx||² = (Qx)^T(Qx) = x^T Q^T Q x = x^T I x = ||x||²",
      "Q, _ = np.linalg.qr(np.random.randn(5, 5))",
      "x = np.random.randn(5)",
      "norm_x = np.linalg.norm(x)",
      "norm_Qx = np.linalg.norm(Q @ x)",
      "assert np.isclose(norm_x, norm_Qx)"
    ],
    "description": "Orthogonal matrix preserves norms"
  },
  "rule-angle-preservation": {
    "prefix": "rule-angle-preserve",
    "body": [
      "# Orthogonal matrix preserves angles:",
      "# angle(Qu, Qv) = angle(u, v)",
      "# cos(θ) = (u · v) / (||u|| ||v||)",
      "Q, _ = np.linalg.qr(np.random.randn(5, 5))",
      "u = np.random.randn(5)",
      "v = np.random.randn(5)",
      "cos_θ = (u @ v) / (np.linalg.norm(u) * np.linalg.norm(v))",
      "cos_θ_Q = (Q @ u @ (Q @ v)) / (np.linalg.norm(Q @ u) * np.linalg.norm(Q @ v))",
      "assert np.isclose(cos_θ, cos_θ_Q)"
    ],
    "description": "Orthogonal matrix preserves angles"
  },
  "rule-lu-decomposition": {
    "prefix": "rule-lu",
    "body": [
      "# LU Decomposition: A = LU",
      "# L is lower triangular with 1s on diagonal",
      "# U is upper triangular",
      "from scipy.linalg import lu",
      "P, L, U = lu(A)",
      "# Note: SciPy includes permutation matrix P",
      "# PA = LU",
      "assert np.allclose(P @ A, L @ U)",
      "# Use for solving systems: Ax = b → LUx = b"
