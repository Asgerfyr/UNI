{
  "rule-orthogonal-transpose-inverse": {
    "prefix": "rule-orthogonal",
    "body": [
      "# Orthogonal Matrix: A^T = A^(-1)",
      "# If Q is orthogonal, then Q^T @ Q = I and Q @ Q^T = I",
      "# Properties:",
      "# - det(Q) = ±1",
      "# - Preserves vector lengths: ||Qx|| = ||x||",
      "# - Preserves angles between vectors"
    ],
    "description": "Orthogonal matrices rule: A^T = A^(-1)"
  },
  "rule-det-product": {
    "prefix": "rule-det-product",
    "body": [
      "# Determinant of Product: det(AB) = det(A) * det(B)",
      "# The determinant of a product equals the product of determinants",
      "det_AB = np.linalg.det(A @ B)",
      "det_A_times_det_B = np.linalg.det(A) * np.linalg.det(B)",
      "assert np.isclose(det_AB, det_A_times_det_B)"
    ],
    "description": "Determinant multiplication rule"
  },
  "rule-det-transpose": {
    "prefix": "rule-det-transpose",
    "body": [
      "# Determinant of Transpose: det(A^T) = det(A)",
      "# The determinant is unchanged by transposition",
      "det_A = np.linalg.det(A)",
      "det_AT = np.linalg.det(A.T)",
      "assert np.isclose(det_A, det_AT)"
    ],
    "description": "Determinant of transpose rule"
  },
  "rule-det-inverse": {
    "prefix": "rule-det-inverse",
    "body": [
      "# Determinant of Inverse: det(A^(-1)) = 1 / det(A)",
      "# The determinant of the inverse is the reciprocal of the determinant",
      "det_A = np.linalg.det(A)",
      "det_A_inv = np.linalg.det(np.linalg.inv(A))",
      "assert np.isclose(det_A_inv, 1 / det_A)"
    ],
    "description": "Determinant of inverse rule"
  },
  "rule-det-scalar-multiply": {
    "prefix": "rule-det-scalar",
    "body": [
      "# Determinant of Scalar Multiple: det(cA) = c^n * det(A)",
      "# where n is the size of the matrix and c is the scalar",
      "c = 2  # scalar",
      "n = A.shape[0]",
      "det_cA = np.linalg.det(c * A)",
      "c_to_n_det_A = (c ** n) * np.linalg.det(A)",
      "assert np.isclose(det_cA, c_to_n_det_A)"
    ],
    "description": "Determinant of scalar multiple rule"
  },
  "rule-det-zero": {
    "prefix": "rule-det-zero",
    "body": [
      "# Determinant is Zero if:",
      "# - Matrix has linearly dependent rows or columns",
      "# - Matrix is singular (non-invertible)",
      "# - A row or column is all zeros",
      "# - Two rows or columns are identical",
      "det_A = np.linalg.det(A)",
      "if np.isclose(det_A, 0):",
      "    print('Matrix is singular and non-invertible')"
    ],
    "description": "Zero determinant conditions"
  },
  "rule-transpose-product": {
    "prefix": "rule-transpose-product",
    "body": [
      "# Transpose of Product: (AB)^T = B^T @ A^T",
      "# Order is reversed when transposing a product",
      "AB_T = (A @ B).T",
      "BT_AT = B.T @ A.T",
      "assert np.allclose(AB_T, BT_AT)"
    ],
    "description": "Transpose of product rule (order reversal)"
  },
  "rule-transpose-inverse": {
    "prefix": "rule-transpose-inverse",
    "body": [
      "# (A^(-1))^T = (A^T)^(-1)",
      "# Transpose and inverse commute",
      "A_inv_T = np.linalg.inv(A).T",
      "AT_inv = np.linalg.inv(A.T)",
      "assert np.allclose(A_inv_T, AT_inv)"
    ],
    "description": "Transpose and inverse commutativity"
  },
  "rule-trace-properties": {
    "prefix": "rule-trace",
    "body": [
      "# Trace Properties:",
      "# trace(A^T) = trace(A)",
      "# trace(A + B) = trace(A) + trace(B)",
      "# trace(cA) = c * trace(A)",
      "# trace(AB) = trace(BA)",
      "# trace(A) = sum of eigenvalues",
      "trace_A = np.trace(A)",
      "sum_eigenvalues = np.sum(np.linalg.eigvals(A))",
