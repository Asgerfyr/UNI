  "rule-qr-decomposition": {
    "prefix": "rule-qr",
    "body": [
      "# QR Decomposition: A = QR",
      "# Q is orthogonal (Q^T @ Q = I)",
      "# R is upper triangular",
      "Q, R = np.linalg.qr(A)",
      "# Verify Q is orthogonal",
      "assert np.allclose(Q.T @ Q, np.eye(Q.shape[1]))",
      "# Verify R is upper triangular",
      "assert np.allclose(np.tril(R, -1), 0)",
      "# Verify reconstruction",
      "assert np.allclose(A, Q @ R)"
    ],
    "description": "QR Decomposition properties"
  },
  "rule-singular-value-decomposition": {
    "prefix": "rule-svd",
    "body": [
      "# Singular Value Decomposition: A = UΣV^T",
      "# U: orthogonal matrix (left singular vectors)",
      "# Σ: diagonal matrix of singular values",
      "# V^T: orthogonal matrix (right singular vectors)",
      "U, s, VT = np.linalg.svd(A)",
      "# Verify U is orthogonal",
      "assert np.allclose(U.T @ U, np.eye(U.shape[1]))",
      "# Verify V is orthogonal",
      "assert np.allclose(VT @ VT.T, np.eye(VT.shape[0]))",
      "# Verify reconstruction",
      "Σ = np.diag(s)",
      "assert np.allclose(A, U @ Σ @ VT)"
    ],
    "description": "Singular Value Decomposition"
  },
  "rule-rank": {
    "prefix": "rule-rank",
    "body": [
      "# Rank Properties:",
      "# rank(A) = number of non-zero singular values",
      "# rank(A^T) = rank(A)",
      "# rank(AB) ≤ min(rank(A), rank(B))",
      "# rank(A) ≤ min(m, n) for m×n matrix",
      "rank_A = np.linalg.matrix_rank(A)",
      "_, s, _ = np.linalg.svd(A)",
      "nonzero_singular_values = np.sum(s > 1e-10)",
      "assert rank_A == nonzero_singular_values"
    ],
    "description": "Rank properties and relationships"
  },
  "rule-orthonormal-vectors": {
    "prefix": "rule-orthonormal",
    "body": [
      "# Orthonormal Vectors:",
      "# Vectors are orthonormal if:",
      "# 1. Each vector has norm 1: ||v_i|| = 1",
