  "rule-gram-schmidt": {
    "prefix": "rule-gram-schmidt",
    "body": [
      "# Gram-Schmidt Orthogonalization:",
      "# Takes linearly independent vectors and produces orthonormal basis",
      "# Process: u_i = v_i - Σ(v_i · u_j) u_j for j < i",
      "# Then normalize: e_i = u_i / ||u_i||",
      "def gram_schmidt(A):",
      "    Q, R = np.linalg.qr(A)",
      "    return Q, R",
      "Q, R = gram_schmidt(A)",
      "# Q contains orthonormal columns"
