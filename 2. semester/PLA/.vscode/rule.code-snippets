  "rule-det-eigenvalues": {
    "prefix": "rule-det-eigenvalues",
    "body": [
      "# Determinant equals product of eigenvalues",
      "# det(A) = λ₁ * λ₂ * ... * λₙ",
      "det_A = np.linalg.det(A)",
      "eigenvalues = np.linalg.eigvals(A)",
