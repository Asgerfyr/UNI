  "rule-similarity-transform": {
    "prefix": "rule-similarity",
    "body": [
      "# Similarity Transformation: B = P^(-1) A P",
      "# Properties preserved under similarity:",
      "# - Eigenvalues are the same",
      "# - Determinant is the same",
      "# - Trace is the same",
      "# - Rank is the same",
      "P = np.random.randn(A.shape[0], A.shape[0])",
      "B = np.linalg.inv(P) @ A @ P",
      "# Same eigenvalues",
      "eig_A = np.sort(np.linalg.eigvals(A))",
      "eig_B = np.sort(np.linalg.eigvals(B))",
