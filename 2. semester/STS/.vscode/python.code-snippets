	"Bayes with Total Probability": {
		"prefix": ["bayes-total", "bayes-med-total"],
		"body": [
			"# Bayes' formel med total sandsynlighed",
			"# P(A|B) = [P(B|A) × P(A)] / [P(B|A) × P(A) + P(B|A^c) × P(A^c)]",
			"",
			"P_${1:sygdom} = ${2:0.01}  # P(A) - a priori sandsynlighed",
			"P_${3:positiv}_given_${1:sygdom} = ${4:0.95}  # P(B|A) - sensitivitet",
			"P_${3:positiv}_given_not_${1:sygdom} = ${5:0.05}  # P(B|A^c) - falsk positiv rate",
			"",
			"# Total sandsynlighed for B",
			"P_${3:positiv} = P_${1:sygdom} * P_${3:positiv}_given_${1:sygdom} + (1 - P_${1:sygdom}) * P_${3:positiv}_given_not_${1:sygdom}",
			"",
			"# Bayes' formel",
			"P_${1:sygdom}_given_${3:positiv} = (P_${3:positiv}_given_${1:sygdom} * P_${1:sygdom}) / P_${3:positiv}",
			"",
			"print(f\"P(${1:sygdom}|${3:positiv}) = {P_${1:sygdom}_given_${3:positiv}:.4f}\")",
			"print(f\"P(${3:positiv}) = {P_${3:positiv}:.4f}\")"
		],
		"description": "Bayes med total sandsynlighed | Bayes' formula with total probability calculation"
	},
	
