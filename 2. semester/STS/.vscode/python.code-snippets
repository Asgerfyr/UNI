	"Two-Sample T-Test (Pooled Variance)": {
		"prefix": ["to-stikprøve-t-test", "two-sample-t"],
		"body": [
			"# To-stikprøve t-test med pooled varians",
			"# H₀: μ₁ = μ₂  vs  H₁: μ₁ ≠ μ₂",
			"# Antager lige varianser: σ₁² = σ₂²",
			"x1 = np.array([${1:sample1}])",
			"x2 = np.array([${2:sample2}])",
			"",
			"n1, n2 = len(x1), len(x2)",
			"mean1, mean2 = np.mean(x1), np.mean(x2)",
			"s1_sq = np.var(x1, ddof=1)",
			"s2_sq = np.var(x2, ddof=1)",
			"",
			"# Pooled varians: s²_p = [(n₁-1)s₁² + (n₂-1)s₂²] / (n₁+n₂-2)",
			"s_pooled_sq = ((n1 - 1) * s1_sq + (n2 - 1) * s2_sq) / (n1 + n2 - 2)",
			"",
			"# Teststatistik: t = (x̄₁ - x̄₂) / √(s²_p(1/n₁ + 1/n₂))",
			"t_stat = (mean1 - mean2) / np.sqrt(s_pooled_sq * (1/n1 + 1/n2))",
			"df = n1 + n2 - 2",
			"",
			"alpha = ${3:0.05}",
			"t_critical = stats.t.ppf(1 - alpha/2, df)",
			"p_value = 2 * (1 - stats.t.cdf(abs(t_stat), df))",
			"",
			"print(f\"H₀: μ₁ = μ₂\")",
			"print(f\"t({df}) = {t_stat:.4f}\")",
			"print(f\"p-værdi = {p_value:.4f}\")",
			"print(f\"Konklusion: {'Forkast H₀' if abs(t_stat) > t_critical else 'Forkast ikke H₀'}\")"
		],
		"description": "To-stikprøve t-test pooled | Two-sample t-test assuming equal variances"
	},
	
