			"print(f\"P(X > {k}) med kontinuitetskorrektion:\")",
			"print(f\"z = ({k}+0.5-{mu:.2f})/{sigma:.4f} = {z:.4f}\")",
			"print(f\"P(X > {k}) = P(Z > {z:.4f}) = {p_greater:.6f}\")"
