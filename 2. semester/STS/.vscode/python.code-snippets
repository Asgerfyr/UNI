	"Normal Distribution from Paired Differences": {
		"prefix": ["udtryk-normalfordeling", "paired-diff-normal", "diff-normal"],
		"body": [
			"# Udtryk normalfordeling fra parrede observationer",
			"# Express normal distribution from paired data differences",
			"# LaTeX: \\mu_D = \\frac{1}{n}\\sum_{i=1}^n D_i",
			"# LaTeX: \\sigma_D^2 = \\frac{1}{n-1}\\sum_{i=1}^n (D_i - \\bar{D})^2",
			"${1:gammel} = np.array([${2:data1}])",
			"${3:ny} = np.array([${4:data2}])",
			"",
			"# Beregn forskelle: D_i = X_{ny,i} - X_{gammel,i}",
			"diff = ${3:ny} - ${1:gammel}",
			"",
			"# Beregn middelværdi (μ) og varians (σ²)",
			"mu = np.mean(diff)",
			"",
			"# Varians med Bessel korrektion (n-1)",
			"variance = np.sum((diff - mu) ** 2) / (len(diff) - 1)",
			"",
			"# Standard afvigelse",
			"sigma = np.sqrt(variance)",
			"",
			"print(f\"Forskelle D = N(μ, σ²)\")",
			"print(f\"D ~ N({mu:.2f}, {variance:.2f})\")",
			"print(f\"μ = {mu:.4f}\")",
			"print(f\"σ² = {variance:.4f}\")",
			"print(f\"σ = {sigma:.4f}\")"
		],
		"description": "Udtryk normalfordeling fra parrede data | Express normal distribution parameters from paired differences"
	}
