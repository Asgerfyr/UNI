			"print(f\"np = {n*p:.1f}, n(1-p) = {n*(1-p):.1f}\")",
			"print(f\"CLT gyldig: {n*p >= 5 and n*(1-p) >= 5}\")",
			"",
			"# Binomial parametre → Normal parametre",
			"mu = n * p",
			"sigma = np.sqrt(n * p * (1 - p))",
